# local-ai environment overrides
#
# Copy to `.env` and edit as needed. All have sensible defaults.
#
#   cp .env.example .env
#   $EDITOR .env

# ── Model storage ───────────────────────────────────────────────────────────
# Where NVFP4+MTP weights live. Must contain qwen3.6-27b-nvfp4-mtp/ subdir.
# Default: ./models/ (inside this repo). Absolute paths recommended.
# MODEL_DIR=/mnt/models

# HuggingFace token (usually not needed — weights are public)
# HF_TOKEN=hf_xxx

# ── GPU ─────────────────────────────────────────────────────────────────────
# GPU device index (default: 0)
# GPU_DEVICE=0

# ── vLLM tuning ─────────────────────────────────────────────────────────────
# Context length (default: 219200, ~224K)
# MAX_MODEL_LEN=219200

# GPU memory utilization (default: 0.94)
# GPU_MEMORY_UTIL=0.94

# Max concurrent sequences (default: 2)
# MAX_NUM_SEQS=2

# MTP speculative tokens (default: 3)
# SPEC_N_MAX=3

# Max batched tokens (default: 4096)
# MAX_NUM_BATCHED=4096

# ── Server ──────────────────────────────────────────────────────────────────
# Host port (default: 8020)
# PORT=8020

# Served model alias (default: qwen3.6)
# MODEL_ALIAS=qwen3.6

# vLLM Docker image
# VLLM_IMAGE=vllm/vllm-openai:v0.22.1

# ── PyTorch allocator ───────────────────────────────────────────────────────
# Default: expandable_segments:True,max_split_size_mb:512
# Set to "expandable_segments:False" if CUDA graph capture OOMs at boot.
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True,max_split_size_mb:512

# Engine selection (text-mtp, vision-mtp, vision-tq-mtp, beellama-dflash-vision,
#                   beellama-qwopus-mtp, glm-5.2-vllm, glm-5.2-sglang)
ENGINE=glm-5.2-vllm
